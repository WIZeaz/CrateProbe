# CrateProbe Backend Configuration Example
# Usage: cp config.toml.example config.toml

[server]
port = 8080
host = "0.0.0.0"

[workspace]
path = "./workspace"

[database]
path = "tasks.db"

[logging]
level = "INFO"
console = true
file = true
file_path = "server.log"

[distributed]
lease_ttl_seconds = 30
runner_offline_seconds = 30
claim_max_jobs_hard_limit = 256

[security]
admin_token = ""
